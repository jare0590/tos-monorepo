{
    "headers": [
      {
        "source": "/assets/(.*)",
        "headers": [
          { "key": "Access-Control-Allow-Origin", "value": "*" },
          { "key": "Access-Control-Allow-Methods", "value": "GET,OPTIONS" },
          { "key": "Access-Control-Allow-Headers", "value": "X-Requested-With, content-type, Authorization" }
        ]
      }
    ]
  }