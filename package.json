{
	"name": "tos-monorepo",
	"private": true,
	"engines": {
		"node": "20.x"
	},
	"packageManager": "pnpm@8.15.6",
	"scripts": {
		"dev": "pnpm -r --parallel dev",
		"build": "pnpm -r build",
		"lint": "pnpm -r lint",
		"test": "pnpm exec vitest run",
		"test:ui": "pnpm -r test:ui",
		"test:coverage": "pnpm -r test --coverage"
	},
	"devDependencies": {
		"@originjs/vite-plugin-federation": "^1.4.1",
		"@tailwindcss/postcss": "^4.2.2",
		"autoprefixer": "^10.5.0",
		"postcss": "^8.5.10",
		"tailwindcss": "^4.2.2"
	},
	"dependencies": {
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-redux": "^9.2.0"
	}
}
